/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();
  /* USER CODE BEGIN 2 */

  HAL_I2C_Slave_Transmit_IT(&hi2c1, (uint8_t *)buffer_tx, 3); // buffer_tx doit être initialisé avant d'armer TX
  HAL_I2C_Slave_Receive_IT(&hi2c1, rxCmd, 2);


  /* USER CODE END 2 */

  /* Call init function for freertos objects (in cmsis_os2.c) */
  MX_FREERTOS_Init();

  /* Start scheduler */
  osKernelStart();

  /* We should never get here as control is now taken by the scheduler */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  * @retval None
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

  /** Initializes the RCC Oscillators according to the specified parameters
  * in the RCC_OscInitTypeDef structure.
  */
  RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
  RCC_OscInitStruct.HSIState = RCC_HSI_ON;
  RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
  RCC_OscInitStruct.PLL.PLLState = RCC_PLL_NONE;
  if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
  {
    Error_Handler();
  }

  /** Initializes the CPU, AHB and APB buses clocks
  */
  RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                              |RCC_CLOCKTYPE_PCLK1|RCC_CLOCKTYPE_PCLK2;
  RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_HSI;
  RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
  RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;
  RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;

  if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_0) != HAL_OK)
  {
    Error_Handler();
  }
}

/* USER CODE BEGIN 4 */
void HAL_I2C_SlaveTxCpltCallback(I2C_HandleTypeDef *hi2c)
{
	xTaskNotifyFromISR(xI2C_TaskHandle, I2C_EVENT_TX_COMPLETE, eSetBits, NULL); // Notify the I2C task of the completed transmission
}

void HAL_I2C_SlaveRxCpltCallback(I2C_HandleTypeDef *hi2c)
{
	//	OSSIGNALSET(I2C_TASKHANDLE, I2C_EVENT_RX_COMPLETE); // SIGNAL THE I2C TASK THAT A COMMAND HAS BEEN RECEIVED

	xTaskNotifyFromISR(xI2C_TaskHandle, I2C_EVENT_RX_COMPLETE, eSetBits, NULL); // Notify the I2C task of the received command
	HAL_I2C_Slave_Receive_IT(hi2c, rxCmd, 2); // Re-arm RX for next command

}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
	  uint32_t current_tick = HAL_GetTick();
  if (GPIO_Pin == BTN_CHANGE_POINT_STATUS_Pin)
  {
	  if (current_tick - last_tick_change_status < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_change_status = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_CHANGE_STATUS, eSetBits, NULL); // Notify the I2C task of the button press event
  }

  else if (GPIO_Pin == BTN_SPE_SELECT_Pin)
  {
	  if (current_tick - last_tick_spe_select < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_spe_select = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_SPECIAL_SEL, eSetBits, NULL); // Notify the I2C task of the reset all status button press event
  }

  else if (GPIO_Pin == BTN_SPE_VALIDATE_Pin)
  {
	  if (current_tick - last_tick_spe_validate < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_spe_validate = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_SPECIAL_VAL, eSetBits, NULL); // Notify the I2C task of the special button press event
  }

  else if (GPIO_Pin == BTN_POINT_NEXT_Pin)
  {
	  if (current_tick - last_tick_next < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_next = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_NEXT, eSetBits, NULL); // Notify the I2C task of the next point button press event
  }

  else if (GPIO_Pin == BTN_POINT_PREV_Pin)
  {
	  if (current_tick - last_tick_prev < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_prev = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_PREV, eSetBits, NULL); // Notify the I2C task of the previous point button press event
  }

  else if (GPIO_Pin == BTN_RESET_ALL_STATUS_Pin)
  {
	  if (current_tick - last_tick_reset_all < DEBOUNCE_DELAY)
	  {
		  return;
	  }
	  last_tick_reset_all = current_tick;
	  xTaskNotifyFromISR(xI2C_TaskHandle, EVENT_BTN_RESET_ALL_STATUS, eSetBits, NULL); // Notify the I2C task of the reset all status button press event
  }
}



