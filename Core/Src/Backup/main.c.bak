static uint32_t last_tick_change_status = 0;
static uint32_t last_tick_spe_select    = 0;
static uint32_t last_tick_spe_validate  = 0;
static uint32_t last_tick_next          = 0;
static uint32_t last_tick_prev          = 0;
static uint32_t last_tick_reset_all     = 0;

#define DEBOUNCE_DELAY 200


